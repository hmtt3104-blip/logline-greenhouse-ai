# Copy to .env — do not commit .env.
#
# Local-only dashboard default for safe testing:
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=5000
# SECRET_KEY=change-me-for-sessions
#
# LAN-exposed testing requires intentional network controls and review:
# DASHBOARD_HOST=0.0.0.0
#
# Telegram (optional; overrides instance/telegram.json when set)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALERTS_ENABLED=0
#
# Person detection is opt-in because it can save camera snapshots under alerts/.
# Requires: sudo apt install python3-opencv
# PERSON_DETECTION_ENABLED=0
# PERSON_DETECTION_INTERVAL_SEC=3
# PERSON_ALERT_COOLDOWN_SEC=60
